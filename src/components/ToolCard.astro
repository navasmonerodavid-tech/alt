---
// ToolCard component for displaying a single tool in a list
export interface Props {
  name: string
  slug: string
  logoUrl?: string | null
  description: string
  priceModel: string
  priceStarting?: number | null
  rating?: number | null
  isOpenSource?: boolean
  tags?: string[]
  affiliateUrl?: string | null
  websiteUrl: string
  lang?: string
}

const {
  name, slug, logoUrl, description, priceModel,
  priceStarting, rating, isOpenSource, tags = [],
  affiliateUrl, websiteUrl, lang = 'es'
} = Astro.props

const isEn = lang === 'en'

const priceLabel = () => {
  if (priceModel === 'free') return isEn ? 'Free' : 'Gratis'
  if (priceModel === 'freemium' && priceStarting)
    return isEn ? `From €${priceStarting}/mo` : `Desde ${priceStarting}€/mes`
  if (priceModel === 'paid' && priceStarting)
    return isEn ? `From €${priceStarting}/mo` : `Desde ${priceStarting}€/mes`
  if (priceModel === 'freemium') return 'Freemium'
  return isEn ? 'Paid' : 'De pago'
}

const ctaUrl = affiliateUrl || websiteUrl
---

<div class="group bg-white border border-[var(--color-border)] rounded-xl p-5 hover:border-[var(--color-green)] hover:shadow-sm transition-all">
  <div class="flex items-start gap-4">
    <div class="w-12 h-12 rounded-lg bg-[var(--color-green-bg)] flex items-center justify-center shrink-0 overflow-hidden">
      {logoUrl ? (
        <img src={logoUrl} alt={`${name} logo`} class="w-8 h-8 object-contain" loading="lazy" />
      ) : (
        <span class="text-lg font-bold text-[var(--color-green)]">{name[0]}</span>
      )}
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <h3 class="font-semibold text-[var(--color-ink)]">
          <a href={`/${isEn ? 'en/tool' : 'herramienta'}/${slug}`} class="hover:text-[var(--color-green)] transition-colors no-underline">
            {name}
          </a>
        </h3>
        {isOpenSource && (
          <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-[var(--color-green-bg)] text-[var(--color-green)] font-medium">
            {isEn ? 'Open Source' : 'Código abierto'}
          </span>
        )}
      </div>
      <p class="text-sm text-[var(--color-ink-light)] mt-1 line-clamp-2">{description}</p>
      <div class="flex items-center gap-3 mt-3 flex-wrap">
        <span class="text-xs font-medium text-[var(--color-ink-light)] bg-[var(--color-cream)] px-2 py-0.5 rounded">
          {priceLabel()}
        </span>
        {rating && (
          <span class="text-xs text-[var(--color-ink-light)]">
            {'⭐'.repeat(Math.round(rating))} <span class="font-medium">{rating}</span>
          </span>
        )}
        {tags.slice(0, 3).map(tag => (
          <span class="text-[10px] text-[var(--color-ink-light)] bg-[var(--color-border-light)] px-1.5 py-0.5 rounded hidden sm:inline">
            {tag}
          </span>
        ))}
      </div>
    </div>
    <div class="shrink-0 self-center">
      <a
        href={ctaUrl}
        target="_blank"
        rel={affiliateUrl ? 'nofollow sponsored' : 'nofollow'}
        class="inline-block text-sm font-medium px-4 py-2 rounded-lg bg-[var(--color-green)] text-white hover:bg-[var(--color-green-light)] transition-colors no-underline whitespace-nowrap"
      >
        {isEn ? 'Visit' : 'Visitar'} →
      </a>
    </div>
  </div>
</div>
