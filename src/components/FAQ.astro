---
// FAQ component with JSON-LD schema
export interface Props {
  faqs: { question: string; answer: string }[]
}

const { faqs } = Astro.props

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
}
---

{faqs.length > 0 && (
  <section class="mt-12">
    <h2 class="text-2xl font-bold mb-6 text-[var(--color-ink)]">Preguntas frecuentes</h2>
    <div class="space-y-3">
      {faqs.map((faq) => (
        <details class="group bg-white border border-[var(--color-border)] rounded-xl">
          <summary class="px-5 py-4 cursor-pointer font-medium text-[var(--color-ink)] list-none flex items-center justify-between">
            {faq.question}
            <span class="text-[var(--color-green)] text-lg group-open:rotate-45 transition-transform">+</span>
          </summary>
          <div class="px-5 pb-4 text-[var(--color-ink-light)] text-sm leading-relaxed">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
    <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
  </section>
)}
