---
import BaseLayout from '@/layouts/BaseLayout.astro'
import type { Tool } from '@/lib/types'

// Comparativa directa entre dos herramientas — se genera dinamicamente
export async function getStaticPaths() {
  return []
}

const { a, b } = Astro.params

const title = `${a} vs ${b}: ¿cuál elegir según tu caso de uso?`
const desc = `Comparativa real entre ${a} y ${b}: precios, funcionalidades, pros, contras y valoraciones. Descubre cuál es mejor para ti.`

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description: desc,
}
---

<BaseLayout title={title} description={desc} schema={schema}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-[var(--color-ink-light)] mb-6">
      <a href="/" class="hover:text-[var(--color-ink)] transition-colors no-underline">Inicio</a>
      <span class="mx-2">/</span>
      <span class="text-[var(--color-ink)]">{a} vs {b}</span>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-ink)] mb-6">
      {a}
      <span class="text-[var(--color-green)] mx-2">vs</span>
      {b}
    </h1>

    <p class="text-lg text-[var(--color-ink-light)] mb-6">
      ¿Estás dudando entre {a} y {b}? Aquí tienes una comparativa lado a lado con datos reales
      para que elijas según tu caso de uso concreto. No hay una "mejor" herramienta universal:
      depende de lo que necesites.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mb-8">
      <div class="bg-white border border-[var(--color-border)] rounded-xl p-6">
        <h2 class="text-xl font-bold text-[var(--color-ink)] mb-3">{a}</h2>
        <p class="text-sm text-[var(--color-ink-light)] mb-4">
          Estamos recopilando los datos de esta herramienta.
        </p>
        <a href={`/alternativas-a/${a.toLowerCase()}`}
          class="inline-block text-sm font-medium text-[var(--color-green)] hover:underline no-underline">
          Ver alternativas a {a} →
        </a>
      </div>
      <div class="bg-white border border-[var(--color-border)] rounded-xl p-6">
        <h2 class="text-xl font-bold text-[var(--color-ink)] mb-3">{b}</h2>
        <p class="text-sm text-[var(--color-ink-light)] mb-4">
          Estamos recopilando los datos de esta herramienta.
        </p>
        <a href={`/alternativas-a/${b.toLowerCase()}`}
          class="inline-block text-sm font-medium text-[var(--color-green)] hover:underline no-underline">
          Ver alternativas a {b} →
        </a>
      </div>
    </div>

    <div class="bg-[var(--color-green-bg)] border border-[var(--color-green)]/20 rounded-xl p-6 text-center">
      <p class="text-sm text-[var(--color-ink-light)]">
        La sección de comparativas detalladas estará disponible pronto. Mientras tanto,
        puedes explorar las alternativas de cada herramienta por separado.
      </p>
    </div>
  </div>
</BaseLayout>
