---
import BaseLayout from '@/layouts/BaseLayout.astro'
import ToolCard from '@/components/ToolCard.astro'
import FAQ from '@/components/FAQ.astro'
import AdSlot from '@/components/AdSlot.astro'
import { getToolBySlug, getAlternativesForTool, getGeneratedContent, getCategoryBySlug, getCategories } from '@/lib/data'
import { getHreflang } from '@/lib/hreflang'
import type { Tool } from '@/lib/types'
import { tools as mockTools } from '@/lib/seed-data'

export async function getStaticPaths() {
  return mockTools.filter(t => t.slug).map(tool => ({
    params: { slug: tool.slug },
  }))
}

const { slug } = Astro.params
const tool = await getToolBySlug(slug!)

if (!tool) return Astro.redirect('/')

const alternatives = await getAlternativesForTool(slug!)
const content = await getGeneratedContent(tool.id)
const cats = await getCategories()
const categorySlug = cats.find(c => c.id === tool.category_id)?.slug || ''
const category = await getCategoryBySlug(categorySlug)

const faqs = content?.faq_es && Array.isArray(content.faq_es)
  ? content.faq_es as { question: string; answer: string }[]
  : []

const pageTitle = `Las ${alternatives.length} mejores alternativas a ${tool.name} en 2026`
const pageDesc = `Comparativa real de alternativas a ${tool.name}: precios, valoraciones, pros y contras. ${alternatives.map(a => a.name).join(', ')}. Encuentra tu herramienta ideal.`

const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: tool.name,
  applicationCategory: category?.name_es || 'BusinessApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: tool.price_starting ? tool.price_starting.toString() : '0',
    priceCurrency: 'EUR',
  },
  aggregateRating: tool.rating_g2 ? {
    '@type': 'AggregateRating',
    ratingValue: tool.rating_g2.toString(),
    bestRating: '5',
    ratingCount: '100',
  } : undefined,
}
---

<BaseLayout title={pageTitle} description={pageDesc} lang="es" canonical={`/alternativas-a/${slug}`} schema={schema} hreflang={getHreflang('alternatives', slug!)}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-[var(--color-ink-light)] mb-6">
      <a href="/" class="hover:text-[var(--color-ink)] transition-colors no-underline">Inicio</a>
      <span class="mx-2">/</span>
      <span class="text-[var(--color-ink)]">Alternativas a {tool.name}</span>
    </nav>

    <!-- Hero -->
    <header class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-ink)] mb-4">
        Las {alternatives.length} mejores alternativas a <span class="text-[var(--color-green)]">{tool.name}</span>
      </h1>
      {content?.intro_es && (
        <p class="text-lg text-[var(--color-ink-light)] max-w-3xl leading-relaxed">
          {content.intro_es}
        </p>
      )}
    </header>

    <!-- Ad -->
    <AdSlot slot="alt-top" format="horizontal" />

    <!-- Comparison Table -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold mb-4 text-[var(--color-ink)]">Comparativa rápida</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm bg-white border border-[var(--color-border)] rounded-xl overflow-hidden">
          <thead>
            <tr class="bg-[var(--color-cream)] border-b border-[var(--color-border)]">
              <th class="text-left p-4 font-semibold text-[var(--color-ink)]">Herramienta</th>
              <th class="text-left p-4 font-semibold text-[var(--color-ink)] hidden sm:table-cell">Precio</th>
              <th class="text-left p-4 font-semibold text-[var(--color-ink)] hidden md:table-cell">Valoración</th>
              <th class="text-left p-4 font-semibold text-[var(--color-ink)] hidden lg:table-cell">Ideal para</th>
              <th class="text-right p-4 font-semibold text-[var(--color-ink)]"></th>
            </tr>
          </thead>
          <tbody>
            {alternatives.map((alt, i) => (
              <tr class="border-b border-[var(--color-border-light)] last:border-0 hover:bg-[var(--color-cream)]/50">
                <td class="p-4">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded bg-[var(--color-green-bg)] flex items-center justify-center shrink-0 overflow-hidden">
                      {alt.logo_url ? (
                        <img src={alt.logo_url} alt={alt.name} class="w-5 h-5 object-contain" loading="lazy" />
                      ) : (
                        <span class="text-xs font-bold text-[var(--color-green)]">{alt.name[0]}</span>
                      )}
                    </div>
                    <div>
                      <span class="font-medium text-[var(--color-ink)]">{alt.name}</span>
                      {alt.is_open_source && (
                        <span class="ml-2 text-[10px] px-1 py-0.5 rounded-full bg-[var(--color-green-bg)] text-[var(--color-green)]">Open Source</span>
                      )}
                    </div>
                  </div>
                </td>
                <td class="p-4 text-[var(--color-ink-light)] hidden sm:table-cell">
                  {alt.price_model === 'free' ? 'Gratis' : alt.price_starting ? `Desde ${alt.price_starting}€/mes` : 'Freemium'}
                </td>
                <td class="p-4 hidden md:table-cell">
                  {alt.rating_g2 && (
                    <span class="text-[var(--color-ink-light)]">⭐ {alt.rating_g2}</span>
                  )}
                </td>
                <td class="p-4 text-[var(--color-ink-light)] text-xs hidden lg:table-cell">
                  {alt.tags?.slice(0, 2).join(', ')}
                </td>
                <td class="p-4 text-right">
                  <a
                    href={alt.affiliate_url || alt.website_url}
                    target="_blank"
                    rel="nofollow sponsored"
                    class="inline-block px-4 py-1.5 text-xs font-medium rounded-lg bg-[var(--color-green)] text-white hover:bg-[var(--color-green-light)] transition-colors no-underline"
                  >
                    Visitar
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Individual Cards -->
    <section>
      <h2 class="text-xl font-semibold mb-4 text-[var(--color-ink)]">Análisis detallado de cada alternativa</h2>
      <div class="space-y-4">
        {alternatives.map(alt => (
          <ToolCard
            name={alt.name}
            slug={alt.slug}
            logoUrl={alt.logo_url}
            description={alt.description_es}
            priceModel={alt.price_model}
            priceStarting={alt.price_starting}
            rating={alt.rating_g2}
            isOpenSource={alt.is_open_source}
            tags={alt.tags}
            affiliateUrl={alt.affiliate_url}
            websiteUrl={alt.website_url}
            lang="es"
          />
        ))}
      </div>
    </section>

    <!-- FAQ -->
    {faqs.length > 0 && <FAQ faqs={faqs} />}

    <!-- Ad Bottom -->
    <AdSlot slot="alt-bottom" format="horizontal" />

    <!-- Related Category -->
    {category && (
      <section class="mt-12">
        <p class="text-sm text-[var(--color-ink-light)]">
          ¿Buscas más herramientas como {tool.name}?{' '}
          <a href={`/herramientas/${category.slug}`} class="text-[var(--color-green)] hover:underline font-medium no-underline">
            Ver todas las herramientas de {category.name_es} →
          </a>
        </p>
      </section>
    )}
  </div>
</BaseLayout>
