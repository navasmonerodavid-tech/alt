---
import BaseLayout from '@/layouts/BaseLayout.astro'
import ToolCard from '@/components/ToolCard.astro'
import { getCategories, getToolsByCategory } from '@/lib/data'

export async function getStaticPaths() {
  const categories = await getCategories()
  return categories.map(cat => ({
    params: { categoria: cat.slug },
  }))
}

const { categoria } = Astro.params
const categories = await getCategories()
const category = categories.find(c => c.slug === categoria!)

if (!category) return Astro.redirect('/')

const tools = await getToolsByCategory(categoria!)

const pageTitle = `${category.name_es} — Las ${tools.length} mejores herramientas en 2026`
const pageDesc = `Comparativa de las mejores herramientas de ${category.name_es.toLowerCase()}. Precios, valoraciones, pros y contras. Encuentra la ideal para ti.`

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: pageTitle,
  description: pageDesc,
  itemListElement: tools.map((t, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: { '@type': 'SoftwareApplication', name: t.name },
  })),
}
---

<BaseLayout title={pageTitle} description={pageDesc} schema={schema}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <nav class="text-sm text-[var(--color-ink-light)] mb-6">
      <a href="/" class="hover:text-[var(--color-ink)] transition-colors no-underline">Inicio</a>
      <span class="mx-2">/</span>
      <span class="text-[var(--color-ink)]">{category.name_es}</span>
    </nav>

    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-ink)] mb-3">
        <span class="text-3xl mr-2">{category.icon}</span>
        {category.name_es}
      </h1>
      <p class="text-lg text-[var(--color-ink-light)]">{category.description_es}</p>
    </header>

    <div class="space-y-4">
      {tools.map(tool => (
        <ToolCard
          name={tool.name}
          slug={tool.slug}
          logoUrl={tool.logo_url}
          description={tool.description_es}
          priceModel={tool.price_model}
          priceStarting={tool.price_starting}
          rating={tool.rating_g2}
          isOpenSource={tool.is_open_source}
          tags={tool.tags}
          affiliateUrl={tool.affiliate_url}
          websiteUrl={tool.website_url}
          lang="es"
        />
      ))}
    </div>

    {tools.length === 0 && (
      <div class="text-center py-16">
        <p class="text-[var(--color-ink-light)]">Pronto añadiremos herramientas de esta categoría.</p>
          <a href="/" class="text-[var(--color-green)] hover:underline mt-2 inline-block no-underline">← Volver al inicio</a>
      </div>
    )}
  </div>
</BaseLayout>
