---
import BaseLayout from '@/layouts/BaseLayout.astro'
import ToolCard from '@/components/ToolCard.astro'
import FAQ from '@/components/FAQ.astro'
import { getToolBySlug, getAlternativesForTool, getGeneratedContent, getTools } from '@/lib/data'
import type { Tool } from '@/lib/types'

export async function getStaticPaths() {
  const tools = await getTools()
  return tools.filter(t => t.slug).map(tool => ({
    params: { slug: tool.slug },
  }))
}

const { slug } = Astro.params
const tool = await getToolBySlug(slug!)

if (!tool) return Astro.redirect('/en')

const alternatives = await getAlternativesForTool(slug!)
const content = await getGeneratedContent(tool.id)

const faqs = content?.faq_en && Array.isArray(content.faq_en)
  ? content.faq_en as { question: string; answer: string }[]
  : []

const pageTitle = `The ${alternatives.length} best ${tool.name} alternatives in 2026`
const pageDesc = `Real comparison of ${tool.name} alternatives: pricing, ratings, pros and cons. ${alternatives.map(a => a.name).join(', ')}. Find your ideal tool.`
---

<BaseLayout title={pageTitle} description={pageDesc} lang="en" canonical={`/en/alternatives-to/${slug}`}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <nav class="text-sm text-[var(--color-ink-light)] mb-6">
      <a href="/en" class="hover:text-[var(--color-ink)] transition-colors no-underline">Home</a>
      <span class="mx-2">/</span>
      <span class="text-[var(--color-ink)]">{tool.name} alternatives</span>
    </nav>

    <header class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-ink)] mb-4">
        The {alternatives.length} best <span class="text-[var(--color-green)]">{tool.name}</span> alternatives
      </h1>
      {content?.intro_en && (
        <p class="text-lg text-[var(--color-ink-light)] max-w-3xl leading-relaxed">
          {content.intro_en}
        </p>
      )}
    </header>

    <section class="mb-10">
      <h2 class="text-xl font-semibold mb-4 text-[var(--color-ink)]">Quick comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm bg-white border border-[var(--color-border)] rounded-xl overflow-hidden">
          <thead>
            <tr class="bg-[var(--color-cream)] border-b border-[var(--color-border)]">
              <th class="text-left p-4 font-semibold text-[var(--color-ink)]">Tool</th>
              <th class="text-left p-4 font-semibold text-[var(--color-ink)] hidden sm:table-cell">Pricing</th>
              <th class="text-left p-4 font-semibold text-[var(--color-ink)] hidden md:table-cell">Rating</th>
              <th class="text-left p-4 font-semibold text-[var(--color-ink)] hidden lg:table-cell">Best for</th>
              <th class="text-right p-4 font-semibold text-[var(--color-ink)]"></th>
            </tr>
          </thead>
          <tbody>
            {alternatives.map(alt => (
              <tr class="border-b border-[var(--color-border-light)] last:border-0 hover:bg-[var(--color-cream)]/50">
                <td class="p-4">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded bg-[var(--color-green-bg)] flex items-center justify-center shrink-0 overflow-hidden">
                      {alt.logo_url ? (
                        <img src={alt.logo_url} alt={alt.name} class="w-5 h-5 object-contain" loading="lazy" />
                      ) : (
                        <span class="text-xs font-bold text-[var(--color-green)]">{alt.name[0]}</span>
                      )}
                    </div>
                    <div>
                      <span class="font-medium text-[var(--color-ink)]">{alt.name}</span>
                      {alt.is_open_source && <span class="ml-2 text-[10px] px-1 py-0.5 rounded-full bg-[var(--color-green-bg)] text-[var(--color-green)]">Open Source</span>}
                    </div>
                  </div>
                </td>
                <td class="p-4 text-[var(--color-ink-light)] hidden sm:table-cell">
                  {alt.price_model === 'free' ? 'Free' : alt.price_starting ? `From €${alt.price_starting}/mo` : 'Freemium'}
                </td>
                <td class="p-4 hidden md:table-cell">
                  {alt.rating_g2 && <span class="text-[var(--color-ink-light)]">⭐ {alt.rating_g2}</span>}
                </td>
                <td class="p-4 text-[var(--color-ink-light)] text-xs hidden lg:table-cell">
                  {alt.tags?.slice(0, 2).join(', ')}
                </td>
                <td class="p-4 text-right">
                  <a href={alt.affiliate_url || alt.website_url} target="_blank" rel="nofollow sponsored"
                    class="inline-block px-4 py-1.5 text-xs font-medium rounded-lg bg-[var(--color-green)] text-white hover:bg-[var(--color-green-light)] transition-colors no-underline">
                    Visit
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <h2 class="text-xl font-semibold mb-4 text-[var(--color-ink)]">Detailed analysis of each alternative</h2>
      <div class="space-y-4">
        {alternatives.map(alt => (
          <ToolCard
            name={alt.name}
            slug={alt.slug}
            logoUrl={alt.logo_url}
            description={alt.description_en}
            priceModel={alt.price_model}
            priceStarting={alt.price_starting}
            rating={alt.rating_g2}
            isOpenSource={alt.is_open_source}
            tags={alt.tags}
            affiliateUrl={alt.affiliate_url}
            websiteUrl={alt.website_url}
            lang="en"
          />
        ))}
      </div>
    </section>

    {faqs.length > 0 && <FAQ faqs={faqs} />}
  </div>
</BaseLayout>
