---
import BaseLayout from '@/layouts/BaseLayout.astro'
import ToolCard from '@/components/ToolCard.astro'
import { getCategories, getToolsByCategory } from '@/lib/data'

export async function getStaticPaths() {
  const categories = await getCategories()
  return categories.map(cat => ({
    params: { category: cat.slug },
  }))
}

const { category } = Astro.params
const categories = await getCategories()
const cat = categories.find(c => c.slug === category!)

if (!cat) return Astro.redirect('/en')

const tools = await getToolsByCategory(category!)
const pageTitle = `${cat.name_en} — The ${tools.length} best tools in 2026`
const pageDesc = `Compare the best ${cat.name_en.toLowerCase()} tools. Pricing, ratings, pros and cons. Find the right one for you.`
---

<BaseLayout title={pageTitle} description={pageDesc} lang="en" canonical={`/en/tools/${category}`}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <nav class="text-sm text-[var(--color-ink-light)] mb-6">
      <a href="/en" class="hover:text-[var(--color-ink)] transition-colors no-underline">Home</a>
      <span class="mx-2">/</span>
      <span class="text-[var(--color-ink)]">{cat.name_en}</span>
    </nav>

    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-ink)] mb-3">
        <span class="text-3xl mr-2">{cat.icon}</span>
        {cat.name_en}
      </h1>
      <p class="text-lg text-[var(--color-ink-light)]">{cat.description_en}</p>
    </header>

    <div class="space-y-4">
      {tools.map(tool => (
        <ToolCard
          name={tool.name}
          slug={tool.slug}
          logoUrl={tool.logo_url}
          description={tool.description_en}
          priceModel={tool.price_model}
          priceStarting={tool.price_starting}
          rating={tool.rating_g2}
          isOpenSource={tool.is_open_source}
          tags={tool.tags}
          affiliateUrl={tool.affiliate_url}
          websiteUrl={tool.website_url}
          lang="en"
        />
      ))}
    </div>

    {tools.length === 0 && (
      <div class="text-center py-16">
        <p class="text-[var(--color-ink-light)]">Tools coming soon for this category.</p>
        <a href="/en" class="text-[var(--color-green)] hover:underline mt-2 inline-block no-underline">← Back home</a>
      </div>
    )}
  </div>
</BaseLayout>
